  {"id":"demo-analiz-016","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı ortalama stokta kalma süresi kaç gündür?","choices":{"A":"45","B":"60","C":"72","D":"90","E":"120"},"correctAnswer":"D","explanation":"Ortalama stokta kalma süresi = 360 / Stok Devir Hızı = 360 / 4 = 90 gün.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"medium","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-017","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"Dikey yüzde analizine göre 2026 stoklarının dönen varlıklar içindeki payı yaklaşık yüzde kaçtır?","choices":{"A":"20","B":"25","C":"30","D":"32","E":"33,33"},"correctAnswer":"E","explanation":"Stokların dönen varlıklardaki payı = 240 / 720 × 100 = yaklaşık %33,33.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"medium","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-018","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"Eğilim yüzdeleri analizinde 2024 yılı 100 kabul edilirse 2026 net satışlarının eğilim yüzdesi kaçtır?","choices":{"A":"120","B":"150","C":"160","D":"180","E":"200"},"correctAnswer":"B","explanation":"Eğilim yüzdesi = 2026 Net Satışlar / 2024 Net Satışlar × 100 = 1.200 / 800 × 100 = 150.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"medium","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-019","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"Karşılaştırmalı analizde 2025'ten 2026'ya net satışların artış oranı yüzde kaçtır?","choices":{"A":"10","B":"15","C":"20","D":"25","E":"50"},"correctAnswer":"C","explanation":"Artış = 1.200 − 1.000 = 200. Artış oranı = 200 / 1.000 × 100 = %20.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"easy","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-020","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"2026 kısa vadeli yabancı kaynakları değişmeden kalırken cari oranın 1,80 olması hedeflenirse dönen varlıklar kaç bin TL artırılmalıdır?","choices":{"A":"144","B":"160","C":"180","D":"200","E":"240"},"correctAnswer":"A","explanation":"Hedef dönen varlık = 480 × 1,80 = 864. Gerekli artış = 864 − 720 = 144 bin TL.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"hard","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true}
