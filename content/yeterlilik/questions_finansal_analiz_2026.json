  {"id":"demo-analiz-005","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı cari oranı kaçtır?","choices":{"A":"1,20","B":"1,33","C":"1,40","D":"1,50","E":"2,00"},"correctAnswer":"D","explanation":"Cari oran = Dönen Varlıklar / Kısa Vadeli Yabancı Kaynaklar = 720 / 480 = 1,50.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"easy","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-006","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı likidite (asit-test) oranı kaçtır?","choices":{"A":"0,75","B":"1,00","C":"1,25","D":"1,50","E":"2,00"},"correctAnswer":"B","explanation":"Likidite oranı = (Dönen Varlıklar − Stoklar) / Kısa Vadeli Yabancı Kaynaklar = (720 − 240) / 480 = 1,00.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"easy","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-007","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı nakit oranı kaçtır?","choices":{"A":"0,10","B":"0,15","C":"0,20","D":"0,25","E":"0,50"},"correctAnswer":"D","explanation":"Nakit oranı = Hazır Değerler / Kısa Vadeli Yabancı Kaynaklar = 120 / 480 = 0,25.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"easy","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-008","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı toplam yabancı kaynaklarının toplam varlıklara oranı yüzde kaçtır?","choices":{"A":"40","B":"45","C":"50","D":"55","E":"60"},"correctAnswer":"C","explanation":"Toplam yabancı kaynaklar = 480 + 320 = 800. Yabancı kaynak oranı = 800 / 1.600 × 100 = %50.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"medium","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-009","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı öz kaynaklarının toplam varlıklara oranı yüzde kaçtır?","choices":{"A":"50","B":"45","C":"40","D":"35","E":"30"},"correctAnswer":"A","explanation":"Öz kaynak oranı = Öz Kaynaklar / Toplam Varlıklar × 100 = 800 / 1.600 × 100 = %50.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"easy","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-010","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı net kâr marjı yüzde kaçtır?","choices":{"A":"8","B":"10","C":"12","D":"15","E":"20"},"correctAnswer":"B","explanation":"Net kâr marjı = Dönem Net Kârı / Net Satışlar × 100 = 120 / 1.200 × 100 = %10.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"easy","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-011","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı brüt satış kârlılığı yüzde kaçtır?","choices":{"A":"20","B":"25","C":"27","D":"30","E":"35"},"correctAnswer":"D","explanation":"Brüt satış kârlılığı = Brüt Satış Kârı / Net Satışlar × 100 = 360 / 1.200 × 100 = %30.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"easy","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-012","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"Toplam varlıkların dönem başı ve dönem sonu ortalaması kullanılırsa DEF İşletmesi'nin 2026 yılı varlık devir hızı kaçtır?","choices":{"A":"0,60","B":"0,75","C":"0,80","D":"1,00","E":"1,20"},"correctAnswer":"C","explanation":"Ortalama toplam varlık = (1.400 + 1.600) / 2 = 1.500. Varlık devir hızı = 1.200 / 1.500 = 0,80.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"medium","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-013","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"2026 net satışlarının tamamı kredili kabul edilirse DEF İşletmesi'nin ticari alacak devir hızı kaçtır?","choices":{"A":"2","B":"3","C":"4","D":"5","E":"6"},"correctAnswer":"E","explanation":"Ticari alacak devir hızı = Kredili Net Satışlar / Ortalama Ticari Alacaklar = 1.200 / 200 = 6.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"medium","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
  {"id":"demo-analiz-014","lessonId":"mali_tablolar_analizi","topicId":"oran_analizi","stimulusId":"demo-analiz-kapsamli-001","question":"DEF İşletmesi'nin 2026 yılı ortalama ticari alacak tahsil süresi kaç gündür?","choices":{"A":"60","B":"72","C":"75","D":"90","E":"120"},"correctAnswer":"A","explanation":"Ortalama tahsil süresi = 360 / Ticari Alacak Devir Hızı = 360 / 6 = 60 gün.","source":{"kind":"generated","styleRef":"2026/1 test biçimi"},"tags":["Özgün Soru","2026 Formatı","ortak tablo","hesaplama"],"difficulty":"medium","updatedAt":"2026-07-13T00:00:00Z","examPeriod":"2026/1 formatına uyumlu","sourceUpdatedAt":"2026-07-13T00:00:00Z","isPremium":false,"isActive":true},
